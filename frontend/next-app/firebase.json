{
  "hosting": {
    "site": "agent-ia-2d81a",
    "public": "out",
    "cleanUrls": true,
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/p/**",
        "destination": "/p/_.html"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
