{
  "hosting": {
    "public": "out",
    "cleanUrls": true,
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/p/**",
        "destination": "/p/_"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
