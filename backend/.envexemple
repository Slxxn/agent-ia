# ============================================================
# Configuration backend Agent Platform
# Copiez ce fichier en ".env" (sans .example) et remplissez
# vos vraies valeurs. Le fichier .env est ignoré par git.
# ============================================================

# Backend LLM à utiliser : "deepseek" (défaut) ou "ollama" (local)
LLM_BACKEND=deepseek

# --- Backend DeepSeek (utilisé si LLM_BACKEND=deepseek) ---
DEEPSEEK_API_KEY=sk-VOTRE_CLE_ICI
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_MODEL_POLISH=deepseek-reasoner
POLISH_ENABLED=1

# --- Backend Ollama (utilisé seulement si LLM_BACKEND=ollama) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:7b

# --- Anti-troncature ---
LLM_MAX_TOKENS=8192
LLM_AUTO_CONTINUE=1
LLM_MAX_CONTINUATIONS=3
